                                "font_type": "default",
                                "font_scale_factor": 1,
                                "shadow": true,
                                "color": [
                                    1,
                                    1,
                                    1
                                ],
                                "anchor_from": "center",
                                "anchor_to": "center"
                            }
                        }
                    ]
                }
            },
            {
                "nav_panel": {
                    "type": "input_panel",
