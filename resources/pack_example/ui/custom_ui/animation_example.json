    "@anim_fade_in": {
        "anim_type": "alpha",
        "duration": 0.5,
        "easing": "linear",
        "from": 0,
        "to": 1
    },
    "@anim_fade_out": {
        "anim_type": "alpha",
        "duration": 0.3,
        "easing": "linear",
        "from": 1,
        "to": 0
    },
    "@anim_slide_from_left": {
        "anim_type": "offset",
        "duration": 0.4,
        "easing": "out_back",
        "from": [
            -200,
            0
        ],
        "to": [
            0,
            0
        ]
    },
    "@anim_slide_from_top": {
        "anim_type": "offset",
        "duration": 0.3,
        "easing": "out_cubic",
        "from": [
            0,
            -100
        ],
        "to": [
            0,
            0
        ]
    },
    "@anim_pulse": {
        "anim_type": "size",
        "duration": 0.8,
        "easing": "in_out_sine",
        "from": [
            100,
            30
        ],
        "to": [
            110,
            34
        ],
        "reversible": true
    },
    "@anim_color_cycle": {
        "anim_type": "color",
        "duration": 2,
        "easing": "in_out_sine",
        "from": [
            1,
            0,
            0
        ],
        "to": [
            0,
            0,
            1
        ],
        "reversible": true
    },
    "@anim_chain_fade_in": {
        "anim_type": "alpha",
        "duration": 0.5,
        "easing": "linear",
        "from": 0,
        "to": 1,
        "next": "@anim_chain_wait"
    },
    "@anim_chain_wait": {
        "anim_type": "wait",
        "duration": 2,
        "easing": "linear",
        "next": "@anim_chain_fade_out"
    },
    "@anim_chain_fade_out": {
        "anim_type": "alpha",
        "duration": 0.5,
        "easing": "linear",
        "from": 1,
        "to": 0,
        "destroy_at_end": "@anim_chain_fade_out"
    },
    "@anim_clip_progress": {
        "anim_type": "clip",
        "duration": 3,
        "easing": "linear",
        "from": 0,
        "to": 1
    },
    "@anim_bounce_in": {
        "anim_type": "offset",
        "duration": 0.6,
        "easing": "out_bounce",
        "from": [
            0,
            -50
        ],
        "to": [
            0,
            0
        ]
    },
    "@anim_elastic": {
        "anim_type": "offset",
        "duration": 1,
        "easing": "out_elastic",
        "from": [
            100,
            0
        ],
        "to": [
            0,
            0
        ]
    }
}