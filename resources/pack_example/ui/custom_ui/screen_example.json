                    "font_scale_factor": 1,
                    "shadow": true,
                    "color": [
                        1,
                        0,
                        0
                    ],
                    "anchor_from": "top_middle",
                    "anchor_to": "top_middle",
                    "offset": [
                        0,
                        20
                    ]
                }
            }
        ]
    },
